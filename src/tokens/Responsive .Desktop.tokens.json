{
  "canvas": {
    "viewport-width": {
      "$type": "dimension",
      "$value": "{dimensions.screens.2xl}"
    },
    "viewport-height": {
      "$type": "dimension",
      "$value": "1024px"
    },
    "canvas-columns": {
      "$type": "dimension",
      "$value": "{dimensions.spacing.3}"
    }
  },
  "theme-spacing": {
    "layout-gutter": {
      "$type": "dimension",
      "$value": "{scale.xl}"
    },
    "layout-gutter-stack-lg": {
      "$type": "dimension",
      "$value": "{scale.xl}"
    },
    "layout-gutter-stack-md": {
      "$type": "dimension",
      "$value": "{scale.xl}"
    },
    "layout-gutter-stack-sm": {
      "$type": "dimension",
      "$value": "{scale.xl}"
    },
    "layout-margin": {
      "$type": "dimension",
      "$value": "{scale.9xl}"
    },
    "layout-pad": {
      "$type": "dimension",
      "$value": "{scale.9xl}"
    },
    "layout-gap-lg": {
      "$type": "dimension",
      "$value": "{scale.9xl}"
    },
    "layout-gap-md": {
      "$type": "dimension",
      "$value": "{scale.6xl}"
    },
    "content-pad-lg": {
      "$type": "dimension",
      "$value": "{scale.8xl}"
    },
    "content-pad-md": {
      "$type": "dimension",
      "$value": "{scale.6xl}"
    },
    "content-pad-sm": {
      "$type": "dimension",
      "$value": "{scale.4xl}"
    },
    "content-gap-lg": {
      "$type": "dimension",
      "$value": "{scale.8xl}"
    },
    "content-gap-md": {
      "$type": "dimension",
      "$value": "{scale.6xl}"
    },
    "content-gap-sm": {
      "$type": "dimension",
      "$value": "{scale.4xl}"
    },
    "content-gap-xs": {
      "$type": "dimension",
      "$value": "{scale.2xl}"
    }
  }
}