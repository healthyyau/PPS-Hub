{
  "Focus rings default": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "4px",
        "color": "{colors.border.brand}"
      },
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "2px",
        "color": "{colors.border.inverse strong}"
      }
    ]
  },
  "Focus rings inverse": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "4px",
        "color": "{colors.border.inverse strong}"
      },
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "2px",
        "color": "{colors.border.strong}"
      }
    ]
  },
  "Focus rings error": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "4px",
        "color": "{colors.foreground.fg-error}"
      },
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "2px",
        "color": "{colors.border.inverse strong}"
      }
    ]
  },
  "Focus rings subtle": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "4px",
        "color": "{colors.border.strong}"
      },
      {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "2px",
        "color": "{colors.border.inverse strong}"
      }
    ]
  },
  "icon light effect": {
    "$type": "shadow",
    "$value": [
      {
        "backgroundBlur": true,
        "blur": "15px"
      },
      {
        "offsetX": "0px",
        "offsetY": "-3px",
        "blur": "2px",
        "spread": "0px",
        "color": "#347ffc1a",
        "inset": true
      },
      {
        "offsetX": "2px",
        "offsetY": "3px",
        "blur": "2px",
        "spread": "0px",
        "color": "#ffffff1a",
        "inset": true
      }
    ]
  },
  "icon dark effect": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "0px",
        "offsetY": "{shadow.md.offset-y}",
        "blur": "{shadow.md.blur-radius}",
        "spread": "{shadow.md.spread-radius}",
        "color": "{shadow.xs.color}"
      },
      {
        "offsetX": "-3px",
        "offsetY": "3px",
        "blur": "14px",
        "spread": "0px",
        "color": "#ffffff4d",
        "inset": true
      },
      {
        "offsetX": "15px",
        "offsetY": "-15px",
        "blur": "27px",
        "spread": "0px",
        "color": "#00000033",
        "inset": true
      },
      {
        "offsetX": "0px",
        "offsetY": "-1px",
        "blur": "2px",
        "spread": "0px",
        "color": "#00276833",
        "inset": true
      }
    ]
  },
  "shadow_2xs": {
    "$type": "shadow",
    "$value": [
      {
        "offsetX": "{shadow.2xs.offset-x}",
        "offsetY": "{shadow.2xs.offset-y}",
        "blur": "{shadow.2xs.blur-radius}",
